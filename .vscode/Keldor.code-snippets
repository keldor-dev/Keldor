            "",
            "## Decision",
            "",
            "${5:What did we decide?}",
            "",
            "## Consequences",
            "",
            "${6:What are the tradeoffs?}"
        ],
        "description": "Insert an Architecture Decision Record template."
    },

    "Keldor YAML GitHub Action PowerShell": {
        "scope": "yaml",
        "prefix": [
            "keldor-gha-powershell",
            "keldor-action-pwsh"
        ],
        "body": [
            "name: ${1:PowerShell}",
            "",
            "on:",
            "  push:",
            "    branches: [ main ]",
            "  pull_request:",
            "    branches: [ main ]",
            "",
            "jobs:",
            "  test:",
            "    name: Test",
            "    runs-on: ubuntu-latest",
            "    steps:",
            "      - name: Checkout",
            "        uses: actions/checkout@v4",
            "",
            "      - name: Test",
            "        shell: pwsh",
            "        run: ${2:Invoke-Pester ./Tests -CI}"
        ],
        "description": "Insert a basic GitHub Actions PowerShell workflow."
    }
}
